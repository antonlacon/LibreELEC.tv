import os
import shutil
import subprocess
import tarfile
import time


BACKUP_DIR = "/storage/.restore"


def remove_dir(directory):
    if os.path.exists(directory):
        shutil.rmtree(directory):


file_list = os.listdir(BACKUP_DIR)
for file in file_list:
    if file.endswith((".tar", ".tar.gz", ".tar.bz2", ".tar.xz")):
        backup_file = file
        print(f"Found backup file: {backup_file}")
        break
backup_file_path = f"{BACKUP_DIR}/{backup_file}"

if backup_file and tarfile.is_tarfile(backup_file_path):
    print("RESTORE IN PROGRESS")
    print("Please do not reboot or turn off this device!")
    try:
        print(f"Extracting file: {backup_file_path}")
        with tarfile.open(name=backup_file_path, mode="r:*") as tarball:
            remove_dir("/storage/.kodi")
            remove_dir("/storage/.cache")
            remove_dir("/storage/.config")
            tarball.extractall()
        print("Extraction successful.")
        sleep_timer = 5
    except tarfile.ReadError:
        print("\nError: Unable to extract file.")
        sleep_timer = 30
else:
    print("\nError: Invalid or corrupt backup file.")
    sleep_timer = 30

print("Removing file to allow normal restart...")
if os.path.exists(backup_file_path):
    os.remove(backup_file_path)
    os.sync()

print(f"Rebooting in {sleep_timer} seconds... ", end="")
for i in range(1, sleep_timer):
    print(i, end="")
    if i < 10:
        print("\b", end="", flush=True)
    else:
        print("\b\b", end="", flush=True)
    time.sleep(1)
subprocess.run(["reboot"], ["-f"])
